{
  "name": "ojibwe-td",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "balance": "esbuild scripts/generate-balance-table.ts --bundle --platform=node --format=esm | node --input-type=module",
    "preevaluate-map": "esbuild scripts/evaluate-map.ts --bundle --platform=node --format=esm --outfile=dist/evaluate-map.mjs",
    "evaluate-map": "node dist/evaluate-map.mjs",
    "check": "npm run typecheck && npm run lint && npm run test",
    "build:ios": "npm run build && bash scripts/sync-ios-version.sh && npx cap sync ios"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.2",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.1.0",
    "phaser": "^3.90.0"
  }
}
